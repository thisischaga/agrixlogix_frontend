# URL du backend (sans slash final). NB : mettre exactement l’Origin autorisé dans MBH-Backend (`CORS_ORIGINS`).
# Exemple local (MBH-Backend sur 4000, routes / et /api montées) :
VITE_API_URL=http://localhost:4000
#
# Si tu déploies sous un sous-chemin (ex. https://mondomaine.com/app/), définis aussi :
# VITE_BASE_URL=/app/
